@{
    ViewData["Title"] = "Panel de Preferencias";
    
    // Obtenemos las preferencias cargadas previamente si existen
    var prefs = ViewBag.Preferencias as GastroMatch_Core.Models.PreferenciaUsuario;
    decimal currentBudget = prefs != null ? prefs.RangoPrecioMax : 85m;
    
    bool hasItaliana = prefs == null || (prefs.TipoCocinaFavorita != null && prefs.TipoCocinaFavorita.Contains("Italiana"));
    bool hasMexicana = prefs != null && prefs.TipoCocinaFavorita != null && prefs.TipoCocinaFavorita.Contains("Mexicana");
    bool hasAsiatica = prefs != null && prefs.TipoCocinaFavorita != null && prefs.TipoCocinaFavorita.Contains("Asiática");
    
    bool isSinGluten = prefs != null && ((prefs.Alergias != null && prefs.Alergias.Contains("Sin Gluten")) || (prefs.RestriccionesDieteticas != null && prefs.RestriccionesDieteticas.Contains("Sin Gluten")));
    bool isSinLactosa = prefs != null && ((prefs.Alergias != null && prefs.Alergias.Contains("Sin Lactosa")) || (prefs.RestriccionesDieteticas != null && prefs.RestriccionesDieteticas.Contains("Sin Lactosa")));
    bool isVegano = prefs != null && ((prefs.Alergias != null && prefs.Alergias.Contains("Vegano")) || (prefs.RestriccionesDieteticas != null && prefs.RestriccionesDieteticas.Contains("Vegano")));
}

<div class="row align-items-center justify-content-center min-vh-75 py-4 g-5">
    <!-- Left Column: Branding -->
    <div class="col-lg-4 text-center text-lg-start">
        <h1 class="display-5 fw-bold mb-3">
            GastroMatch
        </h1>
        <p class="lead text-white-50 mb-4">
            Defina sus preferencias culinarias, restricciones sanitarias de salud y presupuesto máximo para obtener las recomendaciones idóneas directo de nuestra base de datos.
        </p>
    </div>

    <!-- Right Column: Interactive Preferences Form -->
    <div class="col-lg-8">
        <div class="p-4 p-md-5 rounded bg-dark border border-secondary border-opacity-25">
            <h4 class="fw-bold text-white mb-3 pb-2 border-bottom border-secondary border-opacity-25">
                Configuración del Perfil de Preferencias
            </h4>

            <form asp-controller="Recommendation" asp-action="ProcesarPreferencias" method="post" id="preferencesForm">
                <!-- 1. Presupuesto (Slider) -->
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label for="budgetRange" class="form-label text-white fw-semibold mb-0">
                            Presupuesto Máximo
                        </label>
                        <span class="text-primary fw-bold fs-5" id="budgetValue">
                            $@((int)currentBudget) USD
                        </span>
                    </div>
                    <input type="range" class="form-range" id="budgetRange" name="RangoPrecioMax" min="15" max="250" step="5" value="@((int)currentBudget)" oninput="updateBudgetDisplay(this.value)">
                    <div class="d-flex justify-content-between text-white-50 small px-1">
                        <span>$15 USD</span>
                        <span>$130 USD</span>
                        <span>$250 USD</span>
                    </div>
                </div>

                <!-- 2. Gustos Culinarios -->
                <div class="mb-4">
                    <label class="form-label text-white fw-semibold mb-2">
                        Especialidades Culinarias Favoritas
                    </label>
                    <div class="row g-3 p-3 rounded bg-dark-subtle border border-secondary border-opacity-25">
                        <!-- Italiana -->
                        <div class="col-md-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="tipoCocina" value="Italiana" id="gustoItaliana" @(hasItaliana ? "checked" : "")>
                                <label class="form-check-label text-white" for="gustoItaliana">
                                    Italiana
                                </label>
                            </div>
                        </div>
                        <!-- Mexicana -->
                        <div class="col-md-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="tipoCocina" value="Mexicana" id="gustoMexicana" @(hasMexicana ? "checked" : "")>
                                <label class="form-check-label text-white" for="gustoMexicana">
                                    Mexicana
                                </label>
                            </div>
                        </div>
                        <!-- Asiática -->
                        <div class="col-md-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="tipoCocina" value="Asiática" id="gustoAsiatica" @(hasAsiatica ? "checked" : "")>
                                <label class="form-check-label text-white" for="gustoAsiatica">
                                    Asiática
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 3. Salud y Alergias (Switches) -->
                <div class="mb-4">
                    <label class="form-label text-white fw-semibold mb-2">
                        Salud y Restricciones Dietéticas
                    </label>
                    <div class="p-3 rounded bg-dark-subtle border border-secondary border-opacity-25">
                        <!-- Sin Gluten -->
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" role="switch" id="sinGluten" name="salud" value="Sin Gluten" @(isSinGluten ? "checked" : "")>
                            <label class="form-check-label text-white" for="sinGluten">Sin Gluten (Apto Celíacos)</label>
                        </div>
                        <!-- Sin Lactosa -->
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" role="switch" id="sinLactosa" name="salud" value="Sin Lactosa" @(isSinLactosa ? "checked" : "")>
                            <label class="form-check-label text-white" for="sinLactosa">Sin Lactosa (Intolerantes)</label>
                        </div>
                        <!-- Vegano -->
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" id="vegano" name="salud" value="Vegano" @(isVegano ? "checked" : "")>
                            <label class="form-check-label text-white" for="vegano">Vegano (100% Plant-Based)</label>
                        </div>
                    </div>
                </div>

                <!-- 4. Submit Action -->
                <button type="submit" class="btn btn-primary w-100 py-3 fw-bold fs-5 rounded">
                    Buscar Recomendaciones
                </button>
            </form>
        </div>
    </div>
</div>

<!-- PANTALLA 2: Dashboard de Sugerencias Personalizadas -->
@if (ViewBag.TopPicks != null)
{
    var recommendations = ViewBag.TopPicks as List<GastroMatch_Core.Controllers.PlatoRecommendationViewModel>;
    
    <div class="border-top border-secondary border-opacity-25 pt-5 mt-5" id="dashboardSection">
        <div class="mb-4">
            <h3 class="fw-bold text-white">Sugerencias Personalizadas (Top 3)</h3>
            <p class="text-white-50">
                Platos recomendados en base a su presupuesto máximo de $@((int)currentBudget) USD, especialidades preferidas y exclusiones de salud.
            </p>
        </div>

        @if (recommendations != null && recommendations.Any())
        {
            <div class="table-responsive rounded border border-secondary border-opacity-25">
                <table class="table table-dark table-striped table-hover align-middle mb-0">
                    <thead>
                        <tr class="text-uppercase text-secondary small border-bottom border-secondary border-opacity-50">
                            <th scope="col" class="py-3 ps-4">Plato</th>
                            <th scope="col" class="py-3">Restaurante</th>
                            <th scope="col" class="py-3 text-end">Precio</th>
                            <th scope="col" class="py-3 text-end">Distancia</th>
                            <th scope="col" class="py-3 text-end pe-4">Match</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in recommendations)
                        {
                            <tr class="border-bottom border-secondary border-opacity-25">
                                <td class="py-3 ps-4">
                                    <div class="fw-bold text-white fs-6">@item.Plato.NombrePlato</div>
                                    <small class="text-white-50 d-block mt-1">@item.Plato.Descripcion</small>
                                    <div class="mt-2">
                                        @foreach(var ingr in item.Plato.Ingredientes)
                                        {
                                            <span class="badge bg-secondary bg-opacity-25 text-white-50 rounded-pill me-1 small">
                                                @ingr.NombreIngr
                                            </span>
                                        }
                                    </div>
                                </td>
                                <td class="py-3">
                                    <div class="text-white fw-semibold">@(item.Plato.Restaurante?.NombreLocal ?? "N/A")</div>
                                    <small class="text-white-50">@(item.Plato.Restaurante?.Direccion ?? "")</small>
                                </td>
                                <td class="py-3 text-end fw-bold text-success fs-5">
                                    $@item.Plato.Precio.ToString("0.00")
                                </td>
                                <td class="py-3 text-end text-white-50">
                                    @item.DistanceKm.ToString("0.0") km
                                </td>
                                <td class="py-3 text-end pe-4">
                                    <span class="badge bg-primary text-white px-3 py-2 fs-6">
                                        @item.MatchPercentage% Match
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-warning border border-warning-subtle bg-warning bg-opacity-10 text-warning p-4 rounded" role="alert">
                <h5 class="fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Sin Coincidencias</h5>
                <p class="mb-0 small">
                    Ningún plato en la base de datos cumple simultáneamente con sus parámetros de presupuesto, especialidades y exclusiones dietéticas.
                </p>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        function updateBudgetDisplay(val) {
            document.getElementById('budgetValue').innerText = '$' + val + ' USD';
        }
        
        // Desplazamiento automático al panel de resultados si existen
        document.addEventListener("DOMContentLoaded", function() {
            const db = document.getElementById("dashboardSection");
            if (db) {
                db.scrollIntoView({ behavior: "smooth" });
            }
        });
    </script>
}

<style>
    .min-vh-75 {
        min-height: 75vh;
    }
</style>
